NODE_ENV=development
PORT=5000
MONGO_URI=
JWT_SECRET=
CORS_ORIGIN=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# Important:
# - Do not keep spaces around '=' (example: GROQ_MODEL=llama-3.1-8b-instant)
# - Never commit real secrets.
# - In production, use a strong JWT_SECRET (32+ chars) and set CORS_ORIGIN.

# Optional Google auth (additive; does not replace email/password login)
ENABLE_GOOGLE_AUTH=false
GOOGLE_CLIENT_ID=
ENABLE_CLERK_AUTH=false
CLERK_SECRET_KEY=
CLERK_AUDIENCE=
CLERK_AUTHORIZED_PARTIES=
ENABLE_EMAIL_OTP_VERIFICATION=false

# Email OTP verification for signup (required to prevent fake/typo ownership)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Strict LLM backend (chat/profile/explain)
# You can provide one URL or a comma-separated list. The backend will try in order.
STRICT_LLM_BASE_URLS=http://127.0.0.1:8000,https://ayudiet-llm-model.onrender.com
# STRICT_LLM_BASE_URL=http://127.0.0.1:8000
STRICT_LLM_TIMEOUT_MS=25000
AYUDIET_LLM_API_KEY=

# Optional Groq fallback when strict LLM returns fallback/unavailable
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=20000
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Meals generation/chat OpenAI-compatible provider (recommended to set explicitly for production)
MEALS_LLM_MODEL=openai/gpt-oss-120b
MEALS_LLM_BASE_URL=https://api.groq.com/openai/v1
MEALS_LLM_API_KEY=
MEALS_LLM_TIMEOUT_MS=20000

# Optional Gemini fallback when strict LLM returns fallback/unavailable
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_MS=20000

# Uploads are stored on local disk under /uploads (patient docs/photos).
# For persistent production storage across redeploys, use a volume or object storage.
