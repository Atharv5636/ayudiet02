# Use your deployed backend URL in production (example: https://api.yourdomain.com)
VITE_API_URL=http://localhost:5000
# Optional: when frontend runs on localhost, set this only if you want direct backend calls.
# If omitted, localhost uses Vite proxy base "/api" and forwards to VITE_API_URL server-side.
VITE_LOCAL_API_URL=
VITE_ENABLE_GOOGLE_AUTH=false
VITE_GOOGLE_CLIENT_ID=
VITE_ENABLE_CLERK_AUTH=false
VITE_CLERK_PUBLISHABLE_KEY=

# Important:
# - Prefer https URL for VITE_API_URL in production.
# - Do not add spaces around '='.
